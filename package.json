{
  "name": "vue-grid-layout-next",
  "version": "0.0.7",
  "private": false,
  "license": "MIT",
  "main": "dist/vue-grid-layout-next.umd.js",
  "module": "dist/vue-grid-layout-next.es.js",
  "types": "dist/index.d.ts",
  "style": "dist/style.css",
  "files": [
    "dist"
  ],
  "keywords": [
    "vue3",
    "vue-next",
    "grid-layout",
    "vue-grid-layout",
    "vue3-grid-layout",
    "v3-grid-layout"
  ],
  "description": "Vue 3 draggable and resizable grid layout component library",
  "scripts": {
    "start": "vite --host=localhost --port=9018",
    "build:doc": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "build:lib": "vue-tsc --noEmit && vite build --config ./build/lib.config.ts",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages src --ext .ts,.tsx,.vue",
    "typecheck": "vue-tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:zhoulujun/v3-grid-layout.git"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "dependencies": {
    "@vueuse/core": "^8.1.2",
    "interactjs": "^1.10.11",
    "mitt": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/eslint-parser": "^7.26.0",
    "@babel/plugin-transform-runtime": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@blueking/eslint-config-bk": "^2.1.0-beta.7",
    "@blueking/stylelint-config-bk": "^2.0.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-links": "^8.6.0",
    "@storybook/blocks": "^8.6.0",
    "@storybook/vue3-vite": "^8.6.0",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^5.16.0",
    "@typescript-eslint/parser": "^5.16.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitejs/plugin-vue-jsx": "^4.1.0",
    "@vue/babel-plugin-jsx": "^1.2.0",
    "@vue/compiler-sfc": "^3.5.0",
    "@vue/test-utils": "^2.4.0",
    "babel-loader": "^9.2.0",
    "jsdom": "^25.0.0",
    "storybook": "^8.6.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-copy": "^0.1.6",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-md": "^0.20.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
