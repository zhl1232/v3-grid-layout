{
  "name": "vue-grid-layout-next",
  "version": "0.0.7",
  "private": false,
  "license": "MIT",
  "main": "dist/vue-grid-layout-next.umd.js",
  "module": "dist/vue-grid-layout-next.es.js",
  "types": "dist/index.d.ts",
  "style": "dist/style.css",
  "files": [
    "dist"
  ],
  "keywords": [
    "vue3",
    "vue-next",
    "grid-layout",
    "vue-grid-layout",
    "vue3-grid-layout",
    "v3-grid-layout"
  ],
  "description": "Vue 3 draggable and resizable grid layout component library",
  "scripts": {
    "start": "vite --host=localhost --port=9018",
    "build:doc": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "build:lib": "vue-tsc --noEmit && vite build --config ./build/lib.config.ts",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages src --ext .ts,.tsx,.vue",
    "typecheck": "vue-tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit": "npm audit --audit-level=high"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:zhoulujun/v3-grid-layout.git"
  },
  "engines": {
    "node": ">=20.19"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "interactjs": "^1.10.27",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.29.0",
    "@blueking/eslint-config-bk": "^3.0.0-beta.5",
    "@blueking/stylelint-config-bk": "^3.0.0-beta.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/compiler-sfc": "^3.5.13",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "storybook": "^10.4.6",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9",
    "vue": "^3.5.13",
    "vue-tsc": "^3.3.5"
  }
}
